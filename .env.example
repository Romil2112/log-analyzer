# PostgreSQL connection string — required unless using --no-db
LOG_ANALYZER_DSN=postgresql://postgres:postgres@localhost:5432/log_analyzer

# Anthropic API key — only needed for --ai-summary
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional. Enables field-level encryption at rest for the PII columns
# (source_ip, username, raw_line). Leave unset to store them as plaintext.
#   python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: rotating this without re-encrypting existing rows makes previously
# encrypted data unreadable.
DB_ENCRYPTION_KEY=

# Data retention is configured per-run via the --retention-days CLI flag
# (e.g. --retention-days 90); 0 or omitted keeps data forever.
