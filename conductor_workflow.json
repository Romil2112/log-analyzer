{
  "name": "log_analyzer_soc_pipeline",
  "description": "v5: fork the three detectors + ML scoring in parallel, join + tag (severity/MITRE), enrich (threat-intel + GeoIP + per-incident anomaly score + flat mitre_id), summarize via Claude, and push to SOC-Dashboard with run provenance (workflow id + task timings)",
  "version": 5,
  "schemaVersion": 2,
  "ownerEmail": "shahromil71321@gmail.com",
  "timeoutSeconds": 0,
  "inputParameters": [
    "log_path",
    "soc_url",
    "soc_api_key"
  ],
  "tasks": [
    {
      "name": "detect_fork",
      "taskReferenceName": "detect_fork_ref",
      "type": "FORK_JOIN",
      "forkTasks": [
        [
          {
            "name": "detect_brute_force",
            "taskReferenceName": "bf_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "log_path": "${workflow.input.log_path}",
              "log_format": "auto"
            }
          }
        ],
        [
          {
            "name": "detect_port_scan",
            "taskReferenceName": "ps_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "log_path": "${workflow.input.log_path}",
              "log_format": "auto"
            }
          }
        ],
        [
          {
            "name": "detect_404_flood",
            "taskReferenceName": "flood_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "log_path": "${workflow.input.log_path}",
              "log_format": "auto"
            }
          }
        ],
        [
          {
            "name": "ml_score",
            "taskReferenceName": "ml_ref",
            "type": "SIMPLE",
            "inputParameters": {
              "log_path": "${workflow.input.log_path}",
              "log_format": "auto"
            }
          }
        ]
      ]
    },
    {
      "name": "detect_join",
      "taskReferenceName": "detect_join_ref",
      "type": "JOIN",
      "joinOn": [
        "bf_ref",
        "ps_ref",
        "flood_ref",
        "ml_ref"
      ]
    },
    {
      "name": "join_incidents",
      "taskReferenceName": "join_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "brute": "${bf_ref.output.incidents}",
        "port": "${ps_ref.output.incidents}",
        "flood": "${flood_ref.output.incidents}",
        "anomaly_scores": "${ml_ref.output.anomaly_scores}",
        "events": "${ml_ref.output.events}"
      }
    },
    {
      "name": "enrich_geoip",
      "taskReferenceName": "enrich_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "incidents": "${join_ref.output.incidents}",
        "anomaly_scores": "${join_ref.output.anomaly_scores}"
      }
    },
    {
      "name": "generate_claude_summary",
      "taskReferenceName": "summary_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "incidents": "${enrich_ref.output.incidents}",
        "anomaly_scores": "${join_ref.output.anomaly_scores}"
      }
    },
    {
      "name": "push_to_dashboard",
      "taskReferenceName": "push_ref",
      "type": "SIMPLE",
      "inputParameters": {
        "incidents": "${enrich_ref.output.incidents}",
        "soc_url": "${workflow.input.soc_url}",
        "soc_api_key": "${workflow.input.soc_api_key}",
        "workflow_id": "${workflow.workflowId}"
      }
    }
  ],
  "outputParameters": {
    "counts": "${join_ref.output.counts}",
    "summary": "${summary_ref.output.summary}",
    "pushed": "${push_ref.output.pushed}",
    "push_errors": "${push_ref.output.errors}"
  }
}
